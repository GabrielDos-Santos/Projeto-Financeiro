# ── Supabase ──────────────────────────────────────────────────────────
# Dashboard do projeto → Settings → API
# Expostas ao browser (prefixo NEXT_PUBLIC_). A anon key é pública por
# design — quem protege os dados é a Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente servidor. NUNCA use o prefixo NEXT_PUBLIC_ aqui.
# Ignora RLS — usada apenas onde estritamente necessário (ex.: excluir conta).
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────
# URL pública do app (usada em redirects de e-mail de auth a partir da Fase 1).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
